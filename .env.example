# Copy to .env and fill in your values:
#   cp .env.example .env

# Minimal runtime config.
# For a full variable reference, see docs/environment-variables.md

# ── Required ──────────────────────────────────────────────────────────────────
TZ=UTC
POSTGRES_USER=homekit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=homekit_events

# Listener API port (also used by the web container proxy target).
API_PORT=3001

# ── Common optional overrides ────────────────────────────────────────────────
# Linux host deployments: mount host D-Bus so discovery can use host avahi-daemon.
# On most systems this is /run/dbus/system_bus_socket.
HOST_DBUS_SOCKET=/run/dbus/system_bus_socket
# Optional: force discovery to a specific interface (example: bond0, eno1).
# DISCOVER_IFACE=bond0
# Listener network mode (`host` recommended for mDNS/HomeKit/Matter on Linux).
LISTENER_NETWORK_MODE=host
# Web -> listener proxy target for host-network listener.
LISTENER_HOST=host.docker.internal
# If your Docker engine does not support `host-gateway`, set LISTENER_HOST to the
# Docker host LAN IP instead (example: 192.168.1.20).
# Fallback example:
# LISTENER_HOST=192.168.1.20
# Bridge-mode fallback (no host networking):
# LISTENER_NETWORK_MODE=bridge
# LISTENER_HOST=listener
# Optional: override only the web proxy target port (defaults to API_PORT).
# LISTENER_PORT=3001
# Required in production: set API_TOKEN to a long random secret.
# Generate one with: openssl rand -hex 32
API_TOKEN=
# Optional: also require API_TOKEN on GET/HEAD routes.
# API_TOKEN_READS_ENABLED=false
# Optional: comma-separated CORS origin allow-list (example: https://home.example.com,http://localhost:5173).
# If empty, only localhost browser origins are allowed by default.
# CORS_ALLOWED_ORIGINS=
# Set false to disable localhost fallback when CORS_ALLOWED_ORIGINS is empty.
# CORS_ALLOW_LOCALHOST=true
# Maximum JSON body size accepted by the listener API.
# API_JSON_LIMIT=256kb
# Rate limit tuning (per-client, per-window) for DB-backed API routes.
# API_WRITE_RATE_LIMIT_WINDOW_MS=60000
# API_WRITE_RATE_LIMIT_MAX=60
# API_STATS_RATE_LIMIT_WINDOW_MS=60000
# API_STATS_RATE_LIMIT_MAX=120
# EVENTS_RATE_LIMIT_WINDOW_MS=60000
# EVENTS_RATE_LIMIT_MAX=300
# ALERTS_READ_RATE_LIMIT_WINDOW_MS=60000
# ALERTS_READ_RATE_LIMIT_MAX=180
# ALERTS_WRITE_RATE_LIMIT_WINDOW_MS=60000
# ALERTS_WRITE_RATE_LIMIT_MAX=60
# Alerts: allow webhook targets on RFC1918/private ranges (true keeps local automation targets working).
# ALERTS_ALLOW_PRIVATE_TARGETS=true
