# Copy to .env and fill in your values:
#   cp .env.example .env

# Minimal runtime config.
# For a full variable reference, see docs/environment-variables.md

# ── Required ──────────────────────────────────────────────────────────────────
TZ=UTC
POSTGRES_USER=homekit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=homekit_events

# Listener API port (also used by the web container proxy target).
API_PORT=3001

# ── Common optional overrides ────────────────────────────────────────────────
# If web cannot reach listener from inside Docker, set LISTENER_HOST to a LAN IP.
LISTENER_HOST=host.docker.internal
# Set API_TOKEN to require auth for write routes.
API_TOKEN=
